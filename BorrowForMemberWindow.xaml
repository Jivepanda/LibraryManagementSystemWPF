<Window x:Class="PlotTwistLibrary.BorrowForMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Borrow/ Reserve for Member"
        Height="287"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F2EC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Borrow/ Reserve Book for Member"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#241E3E"/>

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Text="Enter the Member ID to assign this borrowed/reserved book."
                   Foreground="#6F6B78"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2"
                   Margin="0,18,0,6"
                   Text="Member ID"
                   FontWeight="SemiBold"
                   Foreground="#241E3E"/>

        <TextBox x:Name="MemberIdTextBox"
                 Grid.Row="3"
                 Height="36"
                 VerticalAlignment="Top"
                 Padding="8"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Height="38"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>

            <Button Content="Borrow/Reserve"
                    Width="100"
                    Height="38"
                    Background="#3F2D7D"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BorrowButton_Click"/>
        </StackPanel>
    </Grid>
</Window>