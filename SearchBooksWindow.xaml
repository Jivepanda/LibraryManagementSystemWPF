<Window x:Class="PlotTwistLibrary.SearchBooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Books"
        Width="1100" Height="600"
        Background="#F5EFE6"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <!-- Top bar -->
            <RowDefinition Height="Auto" />
            <!-- Search bar -->
            <RowDefinition Height="*" />
            <!-- Results -->
        </Grid.RowDefinitions>

        <!-- Top navigation bar -->
        <Border Grid.Row="0" Background="#362C78">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Logo / title -->
                <TextBlock Text="The Plot Twist Library"
                        VerticalAlignment="Center"
                        Foreground="White"
                        FontSize="20"
                        FontWeight="Bold" />

                <!-- Tabs -->
                <StackPanel Grid.Column="1"
                         Orientation="Horizontal"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Button Content="Home"
                         Padding="16,4"
                         Margin="0,0,16,0"
                         Background="#241D5E"
                         Foreground="White"
                         BorderThickness="0" />
                    <Button Content="Search Books"
                         Padding="16,4"
                         Margin="0,0,16,0"
                         Background="Transparent"
                         Foreground="White"
                         BorderBrush="Transparent" />
                    <Button Content="My Loans"
                         Padding="16,4"
                         Margin="0,0,16,0"
                         Background="Transparent"
                         Foreground="White"
                         BorderBrush="Transparent" />
                    <Button Content="Return Book"
                         Padding="16,4"
                         Margin="0,0,16,0"
                         Background="Transparent"
                         Foreground="White"
                         BorderBrush="Transparent" />
                    <Button Content="Logout"
                         Padding="16,4"
                         Margin="0,0,0,0"
                         Background="Transparent"
                         Foreground="#FFB0B0"
                         BorderBrush="Transparent" />
                </StackPanel>

                <!-- User badge -->
                <Border Grid.Column="2"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Padding="12,4"
                     CornerRadius="12"
                     BorderBrush="#B8BCEB"
                     BorderThickness="1">
                    <TextBlock x:Name="UserBadgeText"
                    Text="User:"
                    Foreground="White"
                    FontSize="12" />
                </Border>
            </Grid>
        </Border>

        <!-- Search bar -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                     Margin="0,24,0,16">
            <TextBox x:Name="SearchTextBox"
                     Width="300"
                     Height="32"
                     Margin="0,0,8,0"
                     Padding="8" />
            <Button Content="Search"
                    Width="100"
                    Height="32"
                    Background="#362C78"
                    Foreground="White"
                    Click="SearchButton_Click" />
        </StackPanel>

        <!-- Results grid -->
        <DataGrid x:Name="SearchResultsGrid"
          Grid.Row="2"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          GridLinesVisibility="None"
          RowHeight="32"
          AlternationCount="2">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <!-- Default background -->
                    <Setter Property="Background" Value="#F5EFE6" />

                    <Style.Triggers>
                        <!-- Every 2nd row uses a slightly different colour -->
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#ECE4D8" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="60" />
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="200" />
                <DataGridTextColumn Header="Published"
                            Binding="{Binding PublicationDate, StringFormat=dd/MM/yyyy}"
                            Width="120" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>