<Window x:Class="PlotTwistLibrary.UserDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library System - User Dashboard"
        Width="1100" Height="600"
        Background="#F5EFE6"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top navigation bar -->
        <Border Grid.Row="0" Background="#362C78">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Logo / title -->
                <TextBlock Text="The Plot Twist Library"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold" />

                <!-- Tabs -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="Home"
                            Padding="16,4"
                            Margin="0,0,16,0"
                            Background="#362C78"
                            Foreground="White"
                            BorderThickness="0" />

                    <Button Content="Search Books"
                            Padding="16,4"
                            Margin="0,0,16,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="Transparent"
                            Click="TopBarSearchBooksButton_Click" />

                    <Button Content="Return Book"
                            Padding="16,4"
                            Margin="0,0,16,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="Transparent"
                            Click="HeaderReturnBookButton_Click"/>

                    <Button Content="Logout"
                            Padding="16,4"
                            Margin="0,0,0,0"
                            Background="Transparent"
                            Foreground="#FFB0B0"
                            BorderBrush="Transparent" 
                            Click="LogoutButton_Click" />
                </StackPanel>

                <!-- User badge -->
                <Border Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="12,4"
                        CornerRadius="12"
                        BorderBrush="#B8BCEB"
                        BorderThickness="1">
                    <TextBlock x:Name="UserBadgeText"
                               Text="User:"
                               Foreground="White"
                               FontSize="12" />
                </Border>
            </Grid>
        </Border>

        <!-- Main content -->
        <StackPanel Grid.Row="1"
                    Margin="48,32"
                    Orientation="Vertical">

            <!-- Welcome text -->
            <StackPanel>
                <TextBlock x:Name="WelcomeText"
                           Text="Welcome back"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1F2251" />

                <TextBlock Text="Here's an overview of your library activity"
                           FontSize="14"
                           Margin="0,6,0,0"
                           Foreground="#60637C" />
            </StackPanel>

            <!-- Quick Actions -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,24,0,0">
                <Button Content="Search for a Book"
                        Padding="24,12"
                        Margin="0,0,16,0"
                        Background="#362C78"
                        Foreground="White"
                        BorderBrush="#D0D2E0"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="SearchBooksButton_Click" />

                <Button Content="Return a Book"
                        Padding="24,12"
                        Margin="0,0,16,0"
                        Background="#362C78"
                        Foreground="White"
                        BorderBrush="#D0D2E0"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="ReturnBookButton_Click" />

                <Button Content="Reserve a Book"
                        Padding="24,12"
                        Margin="0,0,16,0"
                        Background="#362C78"
                        Foreground="White"
                        BorderBrush="#D0D2E0"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="ReserveBookQuickMenuButton_Click" />

                <Button x:Name="CollectReservedBookQuickMenuButton"
                        Content="Collect Reserved Book"
                        Padding="24,12"
                        Margin="0,0,16,0"
                        Background="#C29B0C"
                        Foreground="Black"
                        BorderBrush="#A67C00"
                        BorderThickness="1"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        Click="CollectReservedBookQuickMenuButton_Click" />

                <Button Content="View Borrowing History"
                        Padding="24,12"
                        Margin="0,0,0,0"
                        Background="#362C78"
                        Foreground="White"
                        BorderBrush="#D0D2E0"
                        BorderThickness="1"
                        Cursor="Hand" />
            </StackPanel>

            <!-- Current Borrowed Books header -->
            <TextBlock x:Name="BorrowedHeader"
                       Text="Current Borrowed Books and Reservations"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#1F2251"
                       Margin="0,24,0,8" />

            <!-- Borrowed books / reservations table -->
            <DataGrid x:Name="BorrowedBooksGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="40"
                      Margin="0,0,0,0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#362C78" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title"
                                        Binding="{Binding Title}"
                                        Width="*" />

                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding DateString}"
                                        Width="200" />

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="FontWeight" Value="SemiBold" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                        <Setter Property="Foreground" Value="#1F9D55" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Status}" Value="Overdue">
                                        <Setter Property="Foreground" Value="#E53E3E" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Status}" Value="Reserved">
                                        <Setter Property="Foreground" Value="#B7791F" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Status}" Value="Available to Collect">
                                        <Setter Property="Foreground" Value="#2B6CB0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>