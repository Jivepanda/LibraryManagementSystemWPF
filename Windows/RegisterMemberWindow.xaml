<Window x:Class="PlotTwistLibrary.RegisterMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register New Member"
        Width="520"
        Height="620"
        Background="#F5EFE6"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create a Plot Twist Library Account"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#1F2251"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text="Enter your details below to register as a library member."
                   FontSize="14"
                   Foreground="#60637C"
                   Margin="0,0,0,24"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="First Name"
                       FontWeight="SemiBold"
                       Foreground="#1F2251"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="FirstNameTextBox"
                     Height="36"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Last Name"
                       FontWeight="SemiBold"
                       Foreground="#1F2251"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="LastNameTextBox"
                     Height="36"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock Text="Email"
                       FontWeight="SemiBold"
                       Foreground="#1F2251"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="EmailTextBox"
                     Height="36"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,16" VerticalAlignment="Top">
            <TextBlock Text="Phone"
                       FontWeight="SemiBold"
                       Foreground="#1F2251"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="PhoneTextBox"
                     Height="36"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Height="38"
                    Margin="0,0,12,0"
                    Background="White"
                    Foreground="#362C78"
                    BorderBrush="#362C78"
                    BorderThickness="1"
                    Click="CancelButton_Click"/>

            <Button Content="Register"
                    Width="120"
                    Height="38"
                    Background="#C29B0C"
                    Foreground="Black"
                    BorderBrush="#A67C00"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Click="RegisterButton_Click"/>
        </StackPanel>
    </Grid>
</Window>