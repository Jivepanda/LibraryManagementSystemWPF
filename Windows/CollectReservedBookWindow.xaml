<Window x:Class="PlotTwistLibrary.CollectReservedBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Collect Reserved Book"
        Height="350"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select the reserved book that has been collected:"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"/>

        <ListBox x:Name="ReservationsListBox"
                 Grid.Row="1"
                 DisplayMemberPath="Title"
                 MinHeight="160"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="OK"
                    Width="90"
                    Margin="0,0,10,0"
                    Click="OkButton_Click"/>
            <Button Content="Cancel"
                    Width="90"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>