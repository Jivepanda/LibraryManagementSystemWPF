<Window x:Class="LibraryManagementSystem.Windows.StaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Staff Dashboard"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F2EC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3F2D7D">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="The Plot Twist Library"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <TextBlock Grid.Column="1"
                           Text="Staff Dashboard"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="13"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White">
            <StackPanel Orientation="Horizontal" Margin="36,0,0,0">
                <Button Content="Home" Width="78" Height="24" Margin="0,4,8,4"
                        Background="#3F2D7D" Foreground="White" BorderThickness="0"
                        Click="HomeButton_Click"/>
                <Button Content="Books" Width="78" Height="24" Margin="0,4,8,4"
                        Background="Transparent" Foreground="#3B3551" BorderThickness="0"
                        Click="BooksButton_Click"/>
                <Button Content="Loans" Width="78" Height="24" Margin="0,4,8,4"
                        Background="Transparent" Foreground="#3B3551" BorderThickness="0"
                        Click="LoansButton_Click"/>
                <Button Content="Users" Width="78" Height="24" Margin="0,4,8,4"
                        Background="Transparent" Foreground="#3B3551" BorderThickness="0"
                        Click="UsersButton_Click"/>
                <Button Content="Reports" Width="78" Height="24" Margin="0,4,8,4"
                        Background="Transparent" Foreground="#3B3551" BorderThickness="0"
                        Click="ReportsButton_Click"/>
                <Button Content="Logout" Width="78" Height="24" Margin="8,4,0,4"
                        Background="Transparent" Foreground="#C65C4F" BorderThickness="0"
                        Click="LogoutButton_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28,36,28">
                <TextBlock Text="Staff Dashboard"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#241E3E"/>
                <TextBlock Text="Manage books, loans, and library operations"
                           FontSize="14"
                           Foreground="#6F6B78"
                           Margin="0,4,0,24"/>

                <TextBlock Text="Quick Actions"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#241E3E"
                           Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0"
                            Content="Search Books"
                            Height="46"
                            Click="SearchBooksButton_Click"/>

                    <Button Grid.Row="0" Grid.Column="2"
                            Content="View All Borrowed Books"
                            Height="46"
                            Click="ViewAllBorrowedBooksButton_Click"/>

                    <Button Grid.Row="1" Grid.Column="0"
                            Content="View Borrowing Users"
                            Height="46"
                            Margin="0,12,0,0"
                            Click="ViewBorrowingUsersButton_Click"/>

                    <Button Grid.Row="1" Grid.Column="2"
                            Content="Add / Edit Books"
                            Height="46"
                            Margin="0,12,0,0"
                            Click="AddEditBooksButton_Click"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
</Window>