<Window x:Class="PlotTwistLibrary.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Plot Twist Library - Login"
        Width="1000" Height="900"
        Background="#F5EFE6"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: banner image -->
        <Border Grid.Column="0" Background="#1A0A2E" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.268"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Border.RenderTransform>
            <Image Source="pack://application:,,,/Images/PlotTwistBanner.png"
           Stretch="Uniform"
             HorizontalAlignment="Center"
       VerticalAlignment="Center" />
        </Border>
        <!-- Right: welcome and login card -->
        <Grid Grid.Column="1"
              Margin="80"
              VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Welcome text -->
            <StackPanel Grid.Row="0" Margin="0 0 0 40">
                <TextBlock Text="Welcome Back"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F2251" />
                <TextBlock Text="Sign in to access The Plot Twist Library"
                           FontSize="14"
                           Margin="0 8 0 0"
                           Foreground="#60637C" />
            </StackPanel>

            <!-- Login card -->
            <Border Grid.Row="1"
                Background="White"
                CornerRadius="24"
                Padding="40">
                <Border.Effect>
                    <DropShadowEffect Color="#CCCCCC" BlurRadius="20" ShadowDepth="4" Opacity="0.4" />
                </Border.Effect>
                <StackPanel>
                    <!-- Icon + heading -->
                    <TextBlock Text="Member Login"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#1F2251" />

                    <TextBlock Text="Enter your library member ID to continue"
                               FontSize="14"
                               Margin="0 10 0 24"
                               HorizontalAlignment="Center"
                               Foreground="#60637C" />

                    <!-- Member ID label + textbox -->
                    <TextBlock Text="Member ID"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1F2251" />

                    <TextBox x:Name="MemberIdTextBox"
                             Margin="0 6 0 20"
                             Height="36"
                             Padding="8"
                             BorderBrush="#D0D2E0"
                             BorderThickness="1"
                             Background="#F8F9FF"
                             KeyDown="MemberIdTextBox_KeyDown" />

                    <!-- Sign in button -->
                    <StackPanel Margin="0,24,0,0">
                        <Button x:Name="SignInButton"
            Content="Sign in ⟶"
            Height="40"
            Background="#362C78"
            Foreground="White"
            BorderThickness="0"
            FontWeight="SemiBold"
            Click="SignInButton_Click" />

                        <TextBlock HorizontalAlignment="Center"
               Margin="0,16,0,0"
               TextAlignment="Center"
               TextWrapping="Wrap"
               Foreground="#60637C"
               FontSize="12"
               MaxWidth="220">
        <Run Text="Don't have a Member ID? " />
        <Hyperlink Click="RegisterText_MouseLeftButtonUp">
            <Run Text="Register here" />
        </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>